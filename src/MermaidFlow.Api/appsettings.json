{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=MermaidFlowDb;Trusted_Connection=True;"
  },
  "JwtSettings": {
    "Secret": "CHANGE-THIS-TO-A-LONG-RANDOM-SECRET-AT-LEAST-32-CHARS",
    "Issuer": "MermaidFlow",
    "Audience": "MermaidFlow",
    "ExpiryMinutes": 60
  },
  "MermaidRenderer": {
    "PoolSize": 4,
    "RenderTimeoutMs": 15000,
    "MermaidJsUrl": "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"
  }
}
